# MySQL
DB_NAME=appointment_db
DB_USER=appointment_user
DB_PASSWORD=ваш_надёжный_пароль
DB_HOST=localhost
DB_PORT=3306

# FastAPI
SECRET_KEY=сгенерируйте-длинный-секретный-ключ
DEBUG=False
ALLOWED_HOSTS=ваш-домен.ru,127.0.0.1,localhost
SITE_URL=https://ваш-домен.ru
# Оставьте пустым на reg.ru — сайт доступен только по домену, не через localhost:8000
SITE_INTERNAL_URL=
TIMEZONE=Europe/Moscow

# SMTP — письма подтверждения email (создайте ящик noreply@ваш-домен.ru)
# Yandex: smtp.yandex.ru, порт 465, SMTP_USE_SSL=true, пароль приложения
# Mail.ru: smtp.mail.ru, порт 465
# reg.ru: смотрите панель хостинга → Почта → SMTP
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@ваш-домен.ru
SMTP_PASSWORD=пароль_или_пароль_приложения
SMTP_FROM=noreply@ваш-домен.ru
SMTP_FROM_NAME=Все клиенты здесь
SITE_BRAND_NAME=Все клиенты здесь
SUPPORT_EMAIL=kok321416x@yandex.ru
# Яндекс.Метрика (бесплатно): ID счётчика из metrika.yandex.ru
YANDEX_METRIKA_ID=110889652
# Яндекс ID OAuth — https://oauth.yandex.ru/ (Redirect URI: https://ваш-домен.ru/accounts/yandex/callback/)
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
SMTP_USE_SSL=true
EMAIL_VERIFY_HOURS=24
EMAIL_RESEND_MINUTES=5

# Telegram бот
TELEGRAM_BOT_TOKEN=токен_от_BotFather
TELEGRAM_BOT_USERNAME=all_for_clients_bot
# Отдельный секрет для вызовов bot -> API (рекомендуется, не равен TELEGRAM_BOT_TOKEN)
BOT_API_SECRET=сгенерируйте-длинный-случайный-секрет
ADMIN_TELEGRAM_USERNAME=andrievskypsy
# Dual-role: dedupe client+specialist Telegram when same chat (default off until Phase 3)
NOTIFY_DEDUP=false
# Dual-role Phase 5 rollback: true = always create Consultant on signup (old behavior)
FORCE_CONSULTANT_ON_SIGNUP=false
# Mini App / Menu Button URL строится из SITE_URL + /tg/
# В BotFather: Menu Button -> https://ваш-домен.ru/tg/
# Для Telegram WebView на HTTPS лучше none (Secure cookie). Для local http оставьте lax.
SESSION_SAME_SITE=none
# Admin A0/A1: /platform-admin/ (нужен User.is_staff или is_superuser)
PLATFORM_ADMIN_ENABLED=false
