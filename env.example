# MySQL
DB_NAME=appointment_db
DB_USER=appointment_user
DB_PASSWORD=ваш_надёжный_пароль
DB_HOST=localhost
DB_PORT=3306

# FastAPI
SECRET_KEY=сгенерируйте-длинный-секретный-ключ
DEBUG=False
ALLOWED_HOSTS=ваш-домен.ru,127.0.0.1,localhost
SITE_URL=https://ваш-домен.ru
TIMEZONE=Europe/Moscow

# SMTP — письма подтверждения email (создайте ящик noreply@ваш-домен.ru)
# Yandex: smtp.yandex.ru, порт 465, SMTP_USE_SSL=true, пароль приложения
# Mail.ru: smtp.mail.ru, порт 465
# reg.ru: смотрите панель хостинга → Почта → SMTP
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@ваш-домен.ru
SMTP_PASSWORD=пароль_или_пароль_приложения
SMTP_FROM=noreply@ваш-домен.ru
SMTP_FROM_NAME=allyourclients
SMTP_USE_SSL=true
EMAIL_VERIFY_HOURS=24
EMAIL_RESEND_MINUTES=5

# Google OAuth (только Google Calendar, вход через Google можно отключить позже)
GOOGLE_OAUTH_CLIENT_ID=ваш_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=ваш_client_secret

# Telegram бот
TELEGRAM_BOT_TOKEN=токен_от_BotFather
TELEGRAM_BOT_USERNAME=ваш_бот_username
ADMIN_TELEGRAM_USERNAME=andrievskypsy
